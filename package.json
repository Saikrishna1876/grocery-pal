{
  "name": "grocery-pal-workspace",
  "version": "1.0.0",
  "packageManager": "bun@1.3.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/mobile dev",
    "start": "bun run --cwd apps/mobile start",
    "android": "bun run --cwd apps/mobile android",
    "ios": "bun run --cwd apps/mobile ios",
    "web": "bun run --cwd apps/mobile web",
    "convex:dev": "bun run --cwd packages/backend dev",
    "convex:deploy": "bun run --cwd packages/backend deploy",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "turbo:lint": "turbo run lint --filter=mobile",
    "turbo:typecheck": "turbo run typecheck --filter=mobile",
    "turbo:test": "turbo run test --filter=mobile",
    "turbo:check": "turbo run lint typecheck test --filter=mobile"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.8.21"
  },
  "resolutions": {
    "lightningcss": "1.27.0"
  }
}
