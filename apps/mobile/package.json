{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start -c --lan",
    "start": "expo start -c --lan",
    "android": "expo start -c --lan --android",
    "ios": "expo start -c --lan --ios",
    "web": "expo start -c --web",
    "eas:whoami": "bunx eas-cli@latest whoami",
    "eas:build:dev:android": "bunx eas-cli@latest build --platform android --profile development",
    "eas:build:preview:android": "bunx eas-cli@latest build --platform android --profile preview",
    "eas:build:prod:android": "bunx eas-cli@latest build --platform android --profile production",
    "eas:build:prod:ios": "bunx eas-cli@latest build --platform ios --profile production",
    "eas:update:preview": "bunx eas-cli@latest update --branch preview --message \"Preview OTA update\"",
    "eas:update:production": "bunx eas-cli@latest update --branch production --message \"Production OTA update\"",
    "eas:submit:android": "bunx eas-cli@latest submit --platform android --profile production --latest",
    "eas:submit:ios": "bunx eas-cli@latest submit --platform ios --profile production --latest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "convex:dev": "bun run --cwd ../../packages/backend dev",
    "convex:deploy": "bun run --cwd ../../packages/backend deploy"
  },
  "dependencies": {
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@better-auth/expo": "1.4.21",
    "@convex-dev/better-auth": "0.10.13",
    "@react-navigation/core": "^7.17.2",
    "@react-navigation/native": "^7.1.18",
    "@supabase/supabase-js": "^2.99.1",
    "better-auth": "1.4.21",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "convex": "^1.32.0",
    "expo": "55.0.12",
    "expo-constants": "55.0.12",
    "expo-image-picker": "55.0.17",
    "expo-linking": "~55.0.11",
    "expo-network": "55.0.12",
    "expo-router": "55.0.11",
    "expo-secure-store": "55.0.12",
    "expo-splash-screen": "55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "55.0.14",
    "expo-web-browser": "55.0.13",
    "lucide-react-native": "^0.511.0",
    "nativewind": "4.1.23",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-css-interop": "0.1.22",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@expo/ngrok": "^4.1.3",
    "@types/bun": "latest",
    "@types/node": "^24.3.0",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "^55.0.0",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.41",
    "jose": "^6.2.0",
    "typescript": "~5.9.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
