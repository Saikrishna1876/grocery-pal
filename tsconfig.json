{
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "paths": {
      "@/*": [
        "*"
      ]
    }
  },
  "include": [
    "apps/mobile/**/*.ts",
    "apps/mobile/**/*.tsx",
    "packages/backend/**/*.ts"
  ],
  "exclude": [
    "**/node_modules",
    "apps/mobile/tests",
    "packages/backend/convex/_generated",
    "packages/backend/convex/betterAuth/_generated"
  ]
}